# 复制为 .env 后：务必填写 SMTP 账号密码；若 NAS IP 不是 192.168.1.10 请改 ALLOWED_HOSTS / CSRF / CORS 三处里的 IP。
WEB_PORT=28941
DJANGO_SECRET_KEY=zebin-nas-change-if-public-facing-k9Qw4LmR7nX2vYpZ8sT6uH3jFc5BgVa
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.10
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.1.10:28941,http://127.0.0.1:28941,http://localhost:28941
DJANGO_CORS_ALLOWED_ORIGINS=http://192.168.1.10:28941,http://127.0.0.1:28941,http://localhost:28941
DJANGO_SESSION_COOKIE_SECURE=0

SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USE_SSL=1
SMTP_USE_TLS=0
SMTP_FROM_NAME=索评通知
SMTP_USER=
SMTP_PASS=
