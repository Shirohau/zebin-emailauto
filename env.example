# ---------- Django ----------
# 生产环境务必设置强随机密钥
DJANGO_SECRET_KEY=replace_with_long_random_string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# 前端开发（Vite 5173）与生产域名请按实际填写
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# 若全站 HTTPS，可设为 1
DJANGO_SESSION_COOKIE_SECURE=0

# ---------- SMTP（服务端发信，仅 Django 读取）----------
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=yourname@163.com
SMTP_PASS=your_smtp_authorization_code
SMTP_FROM_NAME=索评通知
# 465 通常 SSL；587 常为 TLS（此时 SMTP_USE_TLS=1、SMTP_USE_SSL=0）
SMTP_USE_SSL=1
SMTP_USE_TLS=0

# ---------- 前端构建（可选）----------
# 生产环境前后端不同源时，构建前设为后端公开地址，例如 https://api.example.com
# VITE_API_BASE=https://api.example.com

# ---------- Docker Compose ----------
# 复制本文件为项目根目录 .env：copy env.example .env（Linux/macOS 可用 cp）
WEB_PORT=8080

# NAS 浏览器访问地址写进下列两项（示例 http://192.168.1.10:8080）：
# DJANGO_ALLOWED_HOSTS=192.168.1.10,localhost,nas.local
# DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.1.10:8080

# 外层反向代理终止 HTTPS 时可按需开启：
# DJANGO_USE_X_FORWARDED_HOST=1
# DJANGO_SECURE_PROXY_SSL_HEADER=1
# DJANGO_SESSION_COOKIE_SECURE=1

# SQLite 数据卷（compose 默认挂载到 /data，一般无需改）
# DJANGO_DB_PATH=/data/db.sqlite3
